" 显示行号
set number

" 语法高亮
syntax on

" 设置缩进为4个空格
set tabstop=4
set shiftwidth=4
set expandtab

" 自动缩进
set autoindent
set smartindent

" 编码设置(避免中文乱码)
set encoding=utf-8
set fileencodings=utf-8,gbk,gb2312

" 显示光标所在行
"set cursorline

" 启用鼠标支持
set mouse=a

" 搜索时高亮
set hlsearch

" 搜索时实时预览匹配
set incsearch

